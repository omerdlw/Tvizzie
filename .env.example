NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_PROFILE_MEDIA_BUCKET=profile-media

TMDB_API_KEY=your_tmdb_server_key
NEXT_PUBLIC_TMDB_READ_TOKEN=your_tmdb_public_read_token
TMDB_FETCH_TIMEOUT_MS=4500

EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=no-reply@example.com
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=your_brevo_login
BREVO_SMTP_KEY=your_brevo_key
BREVO_SMTP_FROM=no-reply@example.com

INFRA_INTERNAL_TOKEN=replace_me
PASSWORD_RESET_PROOF_SECRET=replace_me
SIGN_UP_PROOF_SECRET=replace_me
EMAIL_VERIFICATION_SECRET=replace_me
LOGIN_VERIFICATION_SECRET=replace_me
STEP_UP_SECRET=replace_me
RECENT_REAUTH_SECRET=replace_me

AUTH_CHALLENGE_TABLE=auth_challenges
AUTH_AUDIT_TABLE=auth_audit_logs
ACCOUNT_LIFECYCLE_TABLE=account_lifecycle
DATA_PROVIDER=supabase
AUTH_PROVIDER=supabase
REALTIME_MODE=sse
NEXT_PUBLIC_LIVE_TRANSPORT_MODE=sse
NEXT_PUBLIC_ERROR_SAMPLE_RATE=1

RATE_LIMIT_FALLBACK=auto
SUPABASE_PROXY_TIMEOUT_MS=3500
SUPABASE_PROXY_REFRESH_BUFFER_MS=300000
ROLLOUT_DEFAULT_MODE=shadow
ROLLOUT_CANARY_PERCENT=0
CSP_ENFORCE=false

# Keep local secrets in .env.local, staging secrets in platform env vars for staging,
# and production secrets only in production platform env vars.
