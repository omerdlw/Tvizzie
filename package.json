{
  "name": "tvizzie",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=2048' next dev --webpack",
    "dev:clean": "rm -rf .next && NODE_OPTIONS='--max-old-space-size=2048' next dev --webpack",
    "dev:inspect": "NODE_OPTIONS='--inspect --max-old-space-size=2048' next dev --webpack",
    "dev:turbo": "NODE_OPTIONS='--max-old-space-size=3072' next dev --turbopack",
    "dev:webpack": "NODE_OPTIONS='--max-old-space-size=2048' next dev --webpack",
    "analyze": "ANALYZE=true next build",
    "build": "next build",
    "build:debug-memory": "next build --experimental-debug-memory-usage",
    "preflight:prod": "node scripts/preflight-production.mjs",
    "start": "next start",
    "lint": "eslint",
    "seed:social": "node scripts/seed-social-graph.mjs",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@iconify-icon/react": "^3.0.3",
    "@next/bundle-analyzer": "^16.2.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "html-to-image": "^1.11.13",
    "lenis": "^1.3.19",
    "lucide-react": "^0.577.0",
    "next": "^16.2.1",
    "nodemailer": "^8.0.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4"
  }
